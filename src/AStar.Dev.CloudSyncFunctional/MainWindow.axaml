<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AStar.Dev.CloudSyncFunctional"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="AStar.Dev.CloudSyncFunctional.MainWindow"
        x:DataType="local:MainWindowViewModel"
        Title="AStar.Dev.CloudSyncFunctional"
        Width="1280" Height="800">
    <StackPanel Margin="24" Spacing="16">
        <TextBlock Text="AStar.Dev.CloudSyncFunctional" FontSize="26" FontWeight="Bold" />
        <TextBlock Text="{Binding Workspace.CurrentRate}" FontSize="16" />
    </StackPanel>
</Window>
