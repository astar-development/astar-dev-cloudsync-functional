<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AStar.Dev.CloudSyncFunctional.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://AStar.Dev.CloudSyncFunctional/Themes/ColorTokens.axaml"/>
                <ResourceInclude Source="avares://AStar.Dev.CloudSyncFunctional/Themes/Typography.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://AStar.Dev.CloudSyncFunctional/Themes/TypographyStyles.axaml"/>
    </Application.Styles>

</Application>
