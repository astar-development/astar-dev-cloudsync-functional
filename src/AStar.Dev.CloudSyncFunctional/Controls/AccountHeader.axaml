<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AStar.Dev.CloudSyncFunctional.Controls"
             x:Class="AStar.Dev.CloudSyncFunctional.Controls.AccountHeader"
             VerticalContentAlignment="Stretch"
             HorizontalContentAlignment="Stretch">
    <Border x:Name="ContainerBorder" BorderThickness="0,0,0,1" Padding="28,18">
        <Grid ColumnDefinitions="Auto,*,Auto">
            <controls:ProviderMark x:Name="ProviderMarkControl" Grid.Column="0" Size="42" VerticalAlignment="Center" Margin="0,0,14,0"/>
            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock x:Name="NameText"
                               FontFamily="{StaticResource PlusJakartaSans}"
                               FontSize="19"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProviderNameText"
                               FontFamily="{StaticResource JetBrainsMono}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <controls:StatusPill x:Name="StatusPillControl" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="EmailText"
                           FontFamily="{StaticResource JetBrainsMono}"
                           FontSize="12.5"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <controls:AppButton x:Name="PauseButton" Kind="Ghost" ButtonSize="Small" Label="Pause"/>
                <controls:AppButton x:Name="SettingsButton" Kind="Ghost" ButtonSize="Small" Label="Settings"/>
                <controls:AppButton x:Name="MoreButton" Kind="Subtle" ButtonSize="Small" Label="⋯"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
