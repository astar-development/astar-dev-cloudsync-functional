<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AStar.Dev.CloudSyncFunctional.Controls"
             x:Class="AStar.Dev.CloudSyncFunctional.Controls.FolderToolbar"
             VerticalContentAlignment="Stretch"
             HorizontalContentAlignment="Stretch">
    <Border x:Name="ContainerBorder" BorderThickness="0,0,0,1" Padding="28,10">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock x:Name="BreadcrumbText"
                       Grid.Column="0"
                       FontFamily="{StaticResource JetBrainsMono}"
                       FontSize="11"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <controls:StatusPill x:Name="SelectionPill"/>
                <controls:AppButton x:Name="FilterButton" Kind="Ghost" ButtonSize="Sm" Label="Filter"/>
                <controls:AppButton x:Name="ApplyButton" Kind="Primary" ButtonSize="Sm" Label="Apply Changes"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
