<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AStar.Dev.CloudSyncFunctional.Controls"
             x:Class="AStar.Dev.CloudSyncFunctional.Controls.AccountListItem"
             VerticalContentAlignment="Stretch"
             HorizontalContentAlignment="Stretch">
    <Border x:Name="AccentBorder" CornerRadius="7" BorderThickness="2,0,0,0">
        <Border x:Name="Container" Padding="10,8" CornerRadius="5,7,7,5">
            <Grid ColumnDefinitions="Auto,*">
                <Grid Grid.Column="0" Width="26" Height="26" Margin="0,0,10,0" VerticalAlignment="Top">
                    <controls:ProviderMark x:Name="ProviderMarkControl" Size="26"/>
                </Grid>
                <StackPanel Grid.Column="1" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock x:Name="NameText"
                                   FontFamily="{StaticResource PlusJakartaSans}"
                                   FontSize="12.5"
                                   FontWeight="SemiBold"/>
                        <controls:StatusDot x:Name="StatusDotControl" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="EmailText"
                               FontFamily="{StaticResource JetBrainsMono}"
                               FontSize="10.5"/>
                    <StackPanel Spacing="2" Margin="0,2,0,0">
                        <controls:StorageBar x:Name="StorageBarControl"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="StorageText"
                                       FontFamily="{StaticResource JetBrainsMono}"
                                       FontSize="10"/>
                            <TextBlock x:Name="FolderCountText"
                                       FontFamily="{StaticResource JetBrainsMono}"
                                       FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
